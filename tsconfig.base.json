{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["ES2023", "DOM", "DOM.Iterable"],
		"baseUrl": ".",
		"paths": {
			"@elite/game-core": ["packages/game-core/src/index.ts"],
			"@elite/game-renderer": ["packages/game-renderer/src/index.ts"],
			"@elite/game-data": ["packages/game-data/src/index.ts"],
			"@elite/game-input": ["packages/game-input/src/index.ts"]
		},
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"noImplicitOverride": true,
		"noFallthroughCasesInSwitch": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true
	}
}
