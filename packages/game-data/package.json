{
	"name": "@elite/game-data",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"lint": "biome lint src",
		"generate": "npm run build && node dist/generateDataPacks.js",
		"generate:one": "npm run build && node dist/generateDataPacks.js --variants gma85-ntsc"
	}
}
